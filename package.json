{
  "name": "nodehubsapi",
  "private": true,
  "version": "0.1.15",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "typecheck": "npm run typecheck -w apps/api && npm run typecheck -w apps/web",
    "test": "npm run test -w apps/api",
    "db:sqlite:init": "npm run db:init -w apps/api"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.0",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.57.1"
  }
}




